# Manthan API environment. Copy to .env, fill in values. .env is gitignored.

# ── Database ──
DATABASE_URL=postgresql://manthan:manthan_dev@localhost:5433/manthan

# ── Auth (Clerk) ──
# Get from https://dashboard.clerk.com - backend keys
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWT_VERIFICATION_KEY=
# Webhook secret from Clerk dashboard → Webhooks → endpoint settings.
# Starts with `whsec_`. Used to verify svix-signed user.created events.
CLERK_WEBHOOK_SECRET=

# ── LLM (OpenRouter) ──
OPENROUTER_API_KEY=

# ── Coral ──
CORAL_BINARY=/Users/akshmnd/Dev Projects/coral/target/release/coral

# ── Outbound email (Resend) ──
RESEND_API_KEY=
RESEND_FROM_ADDRESS=manthan@miny-labs.com

# ── Webhook secrets (per-source, per-org assigned at OAuth onboarding) ──
STRIPE_WEBHOOK_SECRET=
SLACK_SIGNING_SECRET=
RESEND_INBOUND_WEBHOOK_SECRET=

# ── Event signing key (HMAC over events table rows) ──
EVENT_SIGNING_KEY=change-me-to-a-32-byte-hex

# ── Encryption key for sources.config_encrypted ──
SOURCE_CONFIG_KEY=change-me-to-a-32-byte-hex

# ── Frontend ──
WEB_APP_ORIGIN=http://localhost:5173

# ── Slack workspace (for citation deep-links + Block Kit) ──
SLACK_TOKEN=
SLACK_WORKSPACE_HANDLE=caldera-demo

# ── Source query credentials (read-only) ──
SALESFORCE_API_URL=
SALESFORCE_ACCESS_TOKEN=
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=
INTERCOM_ACCESS_TOKEN=
INTERCOM_WORKSPACE_ID=
ZENDESK_SUBDOMAIN=
ZENDESK_USER_EMAIL_WITH_TOKEN=
ZENDESK_API_TOKEN=
NOTION_API_KEY=
POSTHOG_API_KEY=
POSTHOG_API_BASE=https://us.posthog.com
POSTHOG_PROJECT_ID=
SENTRY_ORG=
SENTRY_TOKEN=
DD_API_KEY=
DD_APPLICATION_KEY=
DD_SITE=datadoghq.com
PAGERDUTY_API_TOKEN=
PAGERDUTY_SUBDOMAIN=

# ── Prettifier model (cheap, fast) ──
MANTHAN_PRETTIFIER_MODEL=google/gemini-3.1-flash-lite

# ── Stripe API (for write actions like refund/dispute response) ──
STRIPE_API_KEY=

# ── Notion decision log parent (where action 'notion_decision_log' writes) ──
NOTION_DECISION_LOG_PARENT_ID=

# ── Manthan Slack briefing channel (optional outbound notify) ──
MANTHAN_SLACK_CHANNEL=
