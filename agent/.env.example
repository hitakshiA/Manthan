# Manthan agent - local config.
# Copy to .env and fill in. .env is gitignored.
#
# This is the ENTIRE list of env vars the agent process reads at
# runtime. The agent does NOT hold per-source credentials (Stripe,
# HubSpot, Notion, etc.) - those live on the Coral side. The agent
# only knows how to ask Coral for data over MCP stdio; Coral is the
# one that authenticates against every connected source.
#
# If you're wiring up Coral itself, see the Coral repo for its own
# `coral source add <kind> --token=...` flow.


# ── LLM ───────────────────────────────────────────────────────────────
# Required. OpenRouter key for the OpenAI-compatible chat endpoint.
OPENROUTER_API_KEY=

# Optional. Defaults to deepseek/deepseek-v4-pro:exacto (cheap + sharp
# enough for the loop's reasoning + tool dispatch). Any OpenRouter
# model that supports function calling works.
MANTHAN_MODEL=deepseek/deepseek-v4-pro:exacto


# ── Coral ─────────────────────────────────────────────────────────────
# Path to the Coral binary the agent will spawn over MCP stdio.
# Defaults to `coral` (assumes it's on PATH). Override if you built
# from source and want to point at a specific build.
CORAL_BINARY=coral
