# ─────────────────────────────────────────────────────────────────────
# Audit pass - repo-specific things we never want tracked.
# ─────────────────────────────────────────────────────────────────────

# Symlinks to sibling repos (e.g. `coral` → ~/Dev Projects/coral, 10GB)
/coral

# Frontend build outputs (Vite → manthan-ui/dist)
dist/
build/

# Pitch video sub-projects - heavy renders, frames, thumbnails. The
# original pitch-video/ is explicit above; the pattern below catches
# any future pitch-* folder so a fresh elevator/30s/teaser cut doesn't
# accidentally end up in history.
pitch-*/
# (anything matching pitch-video/ stays excluded by the explicit rule above)

# Agent run state - scenario JSONs, replay SQL captures, locally-built
# state for the W*R / M*R / V*R / Q*R demos. The seed *scripts* under
# agent/scripts/*.py stay tracked; the .manthan/ produced state does not.
.manthan/

# Video frame caches (ffmpeg / animation tooling output)
**/frames/
**/__hyperframes*
.thumbnails/

# One-off transient scripts (extract_svgs_tmp.js, *_tmp.py, etc.)
*_tmp.*
*-tmp.*
*.tmp

# Agent process logs we tail during dev
/tmp/manthan-*.log
manthan-*.log

# Database backups + agent memory snapshots that shouldn't ride in git.
# (data/* above already catches the main offenders - these belt-and-
# suspenders for files that might land outside data/.)
*.sqlite
*.sqlite3
*.duckdb
*.duckdb.wal
*.vault_key

# Demo video (referenced from README) - explicit exception to the *.mp4 rule above
!manthan-ui/public/demo.mp4
