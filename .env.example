# Manthan - environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# --- LLM (Google AI Studio · Gemini) --------------------------------------
# Manthan uses Gemini through Google AI Studio's OpenAI-compatible chat
# completions endpoint. Get a key here: https://aistudio.google.com/apikey
# Link the key to a paid Cloud project for production quotas.
GEMINI_API_KEY=your_key_here

# Primary model used for Layer 1 column classification + Layer 2 reasoning.
# Default is Gemini 3 Flash - fastest of the Gemini 3.x family, benchmarked
# 2.5x faster than Pro on Manthan's hard-question suite with comparable
# answer quality. Swap to gemini-3.1-pro-preview if you want the deeper
# analysis on dashboard-shaped questions and don't mind the latency.
GEMINI_MODEL=gemini-3-flash-preview

# Fallback cascade - tried in order if the primary is rate-limited or fails.
# Default escalates Flash -> Pro (the deeper model). If both fail, the
# deterministic heuristic classifier kicks in for ingestion.
GEMINI_FALLBACK_MODELS=["gemini-3.1-pro-preview"]

GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# --- Layer 2 agent overrides (optional) -----------------------------------
# By default the agent inherits GEMINI_* above. Set these to use a
# different model/key/url specifically for Layer 2 reasoning.
# AGENT_MODEL=gemini-3-flash-preview
# AGENT_GEMINI_API_KEY=
# AGENT_GEMINI_BASE_URL=

# --- DuckDB ---------------------------------------------------------------
DUCKDB_MEMORY_LIMIT=4GB
DUCKDB_THREADS=4
DUCKDB_TEMP_DIRECTORY=/tmp/duckdb

# --- Storage --------------------------------------------------------------
DATA_DIRECTORY=./data
MAX_UPLOAD_SIZE_MB=500

# --- Server ---------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
LOG_FORMAT=console
