# Manthan — environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# --- LLM Configuration ----------------------------------------------------
# OpenRouter API key (https://openrouter.ai). Required.
OPENROUTER_API_KEY=your_key_here

# Model for Layer 1 column classification
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# Fallback cascade — tried in order if primary fails
OPENROUTER_FALLBACK_MODELS=["qwen/qwen3-next-80b-a3b-instruct:free","nvidia/nemotron-3-nano-30b-a3b:free"]

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- DuckDB ---------------------------------------------------------------
DUCKDB_MEMORY_LIMIT=4GB
DUCKDB_THREADS=4
DUCKDB_TEMP_DIRECTORY=/tmp/duckdb

# --- Storage --------------------------------------------------------------
DATA_DIRECTORY=./data
MAX_UPLOAD_SIZE_MB=500

# --- Server ---------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
LOG_FORMAT=console
