# Manthan — environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# --- LLM Configuration ----------------------------------------------------
# OpenRouter API key (https://openrouter.ai). Required — no default.
OPENROUTER_API_KEY=your_key_here

# Free/paid toggle: true = appends ':free' to model slugs ($0, rate-limited)
#                   false = uses paid tier (fast, uses your balance)
OPENROUTER_FREE_TIER=true

# Primary classifier model (benchmarked: 3.5s for 19-col, 5/5 quality)
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct
# Fallback cascade — tried in order if primary fails
OPENROUTER_FALLBACK_MODELS=["openai/gpt-oss-120b","nvidia/nemotron-3-nano-30b-a3b"]

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- DuckDB ---------------------------------------------------------------
DUCKDB_MEMORY_LIMIT=4GB
DUCKDB_THREADS=4
DUCKDB_TEMP_DIRECTORY=/tmp/duckdb

# --- Sandbox (Python execution) -------------------------------------------
SANDBOX_IMAGE=manthan-sandbox:latest
SANDBOX_MEMORY_LIMIT=2g
SANDBOX_CPU_LIMIT=2
SANDBOX_TIMEOUT_SECONDS=60
SANDBOX_NETWORK_DISABLED=true

# --- Storage --------------------------------------------------------------
DATA_DIRECTORY=./data
MAX_UPLOAD_SIZE_MB=500

# --- Server ---------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
LOG_FORMAT=console
